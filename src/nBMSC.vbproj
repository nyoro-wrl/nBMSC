  <Target Name="EmbedReleaseAssemblies" AfterTargets="ResolveReferences" Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <ItemGroup>
      <EmbeddedAssemblyFiles Include="@(ReferenceCopyLocalPaths)" Condition=" '%(ReferenceCopyLocalPaths.Extension)' == '.dll' ">
        <LogicalName>EmbeddedAssemblies.%(Filename)%(Extension)</LogicalName>
      </EmbeddedAssemblyFiles>
      <EmbeddedResource Include="@(EmbeddedAssemblyFiles)" />
    </ItemGroup>
  </Target>
  <Target Name="CopySupportFiles" AfterTargets="Build">
    <RemoveDir Directories="$(TargetDir)Data" Condition="Exists('$(TargetDir)Data')" />
    <MakeDir Directories="$(TargetDir)Theme" />
    <Copy SourceFiles="@(ThemeFiles)" DestinationFiles="@(ThemeFiles->'$(TargetDir)Theme\%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CleanReleaseFiles" AfterTargets="CopySupportFiles" Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <ItemGroup>
      <ReleaseExtraFiles Include="$(TargetDir)*.xml;$(TargetDir)*.pdb;@(ReferenceCopyLocalPaths->'$(TargetDir)%(DestinationSubDirectory)%(Filename)%(Extension)')" />
    </ItemGroup>
    <Delete Files="@(ReleaseExtraFiles)" />
    <RemoveDir Directories="$(TargetDir)af" Condition="Exists('$(TargetDir)af')" />
  </Target>
